// LÓGICA PARA EL HISTORIAL DE SERIACIONES (VER REGISTROS)
// =========================================================

async function cargarHistorial() {
    console.log("PASO 1: Iniciando función cargarHistorial...");

    // Buscamos el contenedor
    const contenedor = document.getElementById('accordionHistorial') || document.getElementById('divHistorialDinamico');
    
    if (!contenedor) {
        console.log("PASO 2 🛑: No encontré el ID 'accordionHistorial' ni 'divHistorialDinamico' en el HTML. Me detengo.");
        return; 
    }
    console.log("PASO 2 ✅: Contenedor encontrado en el HTML.");

    try {
        console.log("PASO 3: Intentando llamar a Services/ObtenerHistorialService.jsp...");
        // Usamos la O mayúscula como tienes tu archivo físico
        const response = await fetch('Services/ObtenerHistorialService.jsp');
        console.log("PASO 4: El servidor respondió con status:", response.status);

        const result = await response.json();
        console.log("PASO 5: JSON convertido exitosamente. Datos:", result);

        if (result.success) {
            const agrupaciones = result.data;
            let htmlAcordeon = '';
            let index = 0;

            if (Object.keys(agrupaciones).length === 0) {
                console.log("PASO 6: No hay datos, mostrando mensaje de vacío.");
                contenedor.innerHTML = '<div class="alert alert-info text-center mt-3"><i class="fa-solid fa-circle-info"></i> No hay seriaciones registradas aún.</div>';
                return;
            }

            console.log("PASO 6: Armando el Acordeón...");
            for (const [periodo, carreras] of Object.entries(agrupaciones)) {
                const idCollapse = `collapse_${index}`;
                const cantidadRegistros = carreras.length;

                htmlAcordeon += `
                <div class="accordion-item mb-3 border-0">
                    <h2 class="accordion-header d-flex align-items-center gap-3">
                        <button class="accordion-button accordion-historial-header rounded shadow-sm collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#${idCollapse}">
                            <span class="fw-bold text-dark me-2">Periodo:</span> ${periodo}
                        </button>
                        <span class="badge-registros ms-3 shadow-sm">${cantidadRegistros} Registro(s)</span>
                    </h2>
                    
                    <div id="${idCollapse}" class="accordion-collapse collapse" data-bs-parent="#accordionHistorial">
                        <div class="accordion-body pt-4 pb-2">
                `;

                carreras.forEach(carrera => {
                    const fechaMod = carrera.fecha_actualizacion ? carrera.fecha_actualizacion.substring(0, 19) : 'Sin fecha';
                    htmlAcordeon += `
                            <div class="tarjeta-registro-carrera d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="fw-bold mb-1 text-dark">
                                        ${carrera.nombre_carrera} <span class="text-muted fw-normal">|</span> Cuatrimestre ${carrera.grado} <span class="text-muted fw-normal">|</span> Plan ${carrera.cve_plan}
                                    </h6>
                                    <p>Actualizó: Usuario ID ${carrera.id_usuario_actualizo} el ${fechaMod}</p>
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn-accion-historial btn-ver-verde" data-periodo="${carrera.cve_periodo}" data-carrera="${carrera.cve_carrera}" data-plan="${carrera.cve_plan}">Ver</button>
                                    <button class="btn-accion-historial btn-editar-azul" data-periodo="${carrera.cve_periodo}" data-carrera="${carrera.cve_carrera}" data-plan="${carrera.cve_plan}">Editar</button>
                                    <button class="btn-accion-historial btn-eliminar-rojo" data-periodo="${carrera.cve_periodo}" data-carrera="${carrera.cve_carrera}" data-plan="${carrera.cve_plan}">Eliminar</button>
                                </div>
                            </div>
                    `;
                });

                htmlAcordeon += `</div></div></div>`;
                index++;
            }

            contenedor.innerHTML = htmlAcordeon;
            console.log("PASO 7: ¡Terminado! HTML inyectado en pantalla.");
            
        } else {
            console.error("Error del servidor (Success=false):", result.error);
            contenedor.innerHTML = `<div class="alert alert-danger text-center"><i class="fa-solid fa-triangle-exclamation"></i> Error al cargar datos: ${result.error}</div>`;
        }
    } catch (error) {
        console.error("PASO 🛑: Error de Fetch o al convertir JSON:", error);
        contenedor.innerHTML = '<div class="alert alert-danger text-center"><i class="fa-solid fa-wifi"></i> Error de conexión al cargar el historial. Verifica consola.</div>';
    }
}

// Escuchamos el evento de carga de la página para disparar la función
document.addEventListener('DOMContentLoaded', () => {
    cargarHistorial();
});
