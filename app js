async function llenarFiltrosEnSilencio(periodo, carrera, plan) {
    try {
        console.log("🤫 Llenando filtros superiores en silencio...");
        
        const periodos = await fetchFiltros('periodos');
        if (typeof selPeriodo !== 'undefined' && selPeriodo) {
            periodos.forEach(p => selPeriodo.add(new Option(p.descripcion, p.cve_periodo)));
            selPeriodo.value = periodo;
            selPeriodo.disabled = true; // Bloqueado
        }

        const carreras = await fetchFiltros('carreras');
        if (typeof selCarrera !== 'undefined' && selCarrera) {
            selCarrera.disabled = false;
            carreras.forEach(c => selCarrera.add(new Option(c.descripcion, c.cve_carrera)));
            selCarrera.value = carrera;
            selCarrera.disabled = true; // Bloqueado
        }

        const planes = await fetchFiltros('planes', { cve_carrera: carrera });
        if (typeof selPlan !== 'undefined' && selPlan) {
            selPlan.disabled = false;
            planes.forEach(p => selPlan.add(new Option(p.descripcion, p.cve_plan)));
            selPlan.value = plan;
            selPlan.disabled = true; // Bloqueado
        }
        
    } catch (error) {
        console.error("❌ Error al llenar filtros en silencio:", error);
    }
}

async function cargarDatosParaEditar(periodo, carrera, plan) {
    try {
        console.log("🔍 Buscando materias guardadas en la BD...");
        const resp = await fetch(`Services/ObtenerDetalleSeriacionService.jsp?periodo=${periodo}&carrera=${carrera}&plan=${plan}`);
        const res = await resp.json();

        if (res.success && res.data && res.data.length > 0) {
            const materias = res.data;
            console.log("🔥 Inyectando materias en la tabla...", materias);

            const tbodyMaterias = document.getElementById('tbodyMaterias') || document.querySelector('.tbodyMaterias');
            const contenedorTabla = document.getElementById('contenedorTabla');
            const contenedorGrafica = document.getElementById('contenedorGrafica');
            const badgeTotal = document.getElementById('badgeTotal');
            const tituloGrafica = document.getElementById('tituloGrafica'); // Por si lo usas

            if (!tbodyMaterias) return;

            // 1. Llenamos el select del grado con el dato que viene de la BD
            const gradoMat = materias[0].grado;
            if (typeof selGrado !== 'undefined' && selGrado && gradoMat) {
                selGrado.innerHTML = ''; 
                selGrado.add(new Option(`${gradoMat}° Cuatrimestre`, gradoMat));
                selGrado.value = gradoMat;
                selGrado.disabled = true; // Bloqueado
            }

            // Limpiamos la tabla
            tbodyMaterias.innerHTML = '';

            const formatFechaInput = (fechaDDMM) => {
                if (!fechaDDMM || fechaDDMM === 'N/A') return '';
                const partes = fechaDDMM.split('/');
                if (partes.length === 3) return `${partes[2]}-${partes[1]}-${partes[0]}`;
                return fechaDDMM;
            };

            // Dibujamos filas
            materias.forEach((mat, idx) => {
                const cve = mat.cve_materia ? mat.cve_materia : `edit_${idx}`; 
                const tr = document.createElement('tr');
                tr.setAttribute('data-materia', cve); 
                
                tr.innerHTML = `
                    <td class="text-start materia-titulo">${mat.nombre}</td>
                    <td>
                        <select class="form-select form-select-sm text-center" id="tipo_${cve}">
                            ${typeof opcionesTipoAsignaturaHTML !== 'undefined' && opcionesTipoAsignaturaHTML !== '' ? opcionesTipoAsignaturaHTML : '<option value="1">Virtual</option><option value="2">Semipresencial</option>'}
                        </select>
                    </td>
                    <td>
                        <input type="text" inputmode="numeric" oninput="this.value = this.value.replace(/[^0-9]/g, '')" 
                        class="form-control form-control-sm text-center calculo-duracion mx-auto" 
                        style="width: 70px;" data-cve="${cve}" id="inicio_${cve}" value="${mat.inicio}">
                    </td>
                    <td>
                        <input type="text" inputmode="numeric" oninput="this.value = this.value.replace(/[^0-9]/g, '')" 
                        class="form-control form-control-sm text-center calculo-duracion mx-auto" 
                        style="width: 70px;" data-cve="${cve}" id="fin_${cve}" value="${mat.fin}">
                    </td>
                    <td>
                        <input type="text" class="form-control form-control-sm text-center mx-auto input-duracion-readonly" 
                        style="width: 70px;" readonly id="duracion_${cve}" value="${mat.duracion}">
                    </td>
                    <td><input type="date" class="form-control form-control-sm text-center text-muted" id="fechaInicio_${cve}" value="${formatFechaInput(mat.fechaIni)}"></td>
                    <td><input type="date" class="form-control form-control-sm text-center text-muted" id="fechaFin_${cve}" value="${formatFechaInput(mat.fechaFin)}"></td>
                `;
                
                tbodyMaterias.appendChild(tr);

                // Asignar el valor al select de tipo
                setTimeout(() => {
                    const selectTipo = document.getElementById(`tipo_${cve}`);
                    if(selectTipo) selectTipo.value = mat.tipoId;
                }, 50);
            });

            // Mostramos los contenedores principales
            if (contenedorTabla) contenedorTabla.classList.remove('d-none');
            if (contenedorGrafica) contenedorGrafica.classList.remove('d-none');

            // 2. ACTUALIZACIÓN TERCA (A prueba de fallos)
            setTimeout(() => {
                // Buscamos el contador usando tu variable global o buscando la clase de la etiqueta
                const etiquetaContador = (typeof badgeTotal !== 'undefined' ? badgeTotal : null) 
                                      || document.getElementById('badgeTotal') 
                                      || document.querySelector('.badge:last-of-type') 
                                      || document.querySelector('span:contains("materias")');

                if (etiquetaContador) {
                    etiquetaContador.textContent = `${materias.length} materia${materias.length !== 1 ? 's' : ''}`;
                    console.log("✅ Contador actualizado con éxito a:", materias.length);
                } else {
                    console.log("⚠️ No encontré la etiqueta del contador en el HTML.");
                }
                
                // También actualizamos el título de la gráfica si existe
                const tituloGrafica = document.getElementById('tituloGrafica') || document.querySelector('.titulo-grafica');
                if (tituloGrafica) {
                    tituloGrafica.textContent = `MODO EDICIÓN (Cuatrimestre ${gradoMat})`;
                }
            }, 1000);

            // Disparamos el diagrama de Gantt
            if (typeof actualizarGrafica === 'function') {
                setTimeout(actualizarGrafica, 1100); 
            }

        } else {
            console.warn("⚠️ No se encontraron materias guardadas.");
        }
    } catch (error) {
        console.error("❌ Error al cargar datos de edición:", error);
    }
}
